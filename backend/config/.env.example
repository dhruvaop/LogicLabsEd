# ──────────────────────────────────────────────
# Application
# ──────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ──────────────────────────────────────────────
# Database
# ──────────────────────────────────────────────
# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>

# ──────────────────────────────────────────────
# Mail (SMTP)
# ──────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_USER=<your-email@gmail.com>
MAIL_PASS=<your-app-password>
FROM_NAME=<Your Name>
FROM_EMAIL=<your-email@gmail.com>
SITE_OWNER_EMAIL=<your-email@gmail.com>

# ──────────────────────────────────────────────
# Cloudinary
# ──────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=<your-cloud-name>
CLOUDINARY_API_KEY=<your-api-key>
CLOUDINARY_API_SECRET=<your-api-secret>

# ──────────────────────────────────────────────
# JWT
# ──────────────────────────────────────────────
# Use a long, random string (e.g. `openssl rand -hex 64`)
JWT_SECRET=<replace-with-a-strong-random-secret>
JWT_EXPIRE=30d
JWT_COOKIE_EXPIRE=3000

# ──────────────────────────────────────────────
# File Upload Limits
# ──────────────────────────────────────────────
AVATAR_FOLDER_NAME=StudyNotion/avatars
THUMBNAIL_FOLDER_NAME=StudyNotion/thumbnail
VIDEO_FOLDER_NAME=StudyNotion/video
AVATAR_MAX_SIZE=512000
THUMBNAIL_MAX_SIZE=1048576
VIDEO_MAX_SIZE=52428800

# ──────────────────────────────────────────────
# Site URLs
# ──────────────────────────────────────────────
STUDY_NOTION_BACKEND_SITE=http://localhost:4000
STUDY_NOTION_FRONTEND_SITE=http://localhost:3000

# ──────────────────────────────────────────────
# Razorpay
# ──────────────────────────────────────────────
RAZORPAY_PAY_KEY_ID=<your-razorpay-key-id>
RAZORPAY_PAY_KEY_SECRET=<your-razorpay-key-secret>
RAZORPAY_WEBHOOK_SECRET=<your-razorpay-webhook-secret>
RAZORPAY_MERCHANT_ID=<your-razorpay-merchant-id>

# ──────────────────────────────────────────────
# Redis (optional cache layer)
# ──────────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
